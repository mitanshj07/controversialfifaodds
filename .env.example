# Local server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
REPLAY_SPEED=1
CONTEST_ENTRY_WINDOW_MS=20000

# Future live TxLINE mode (keep server-side; never expose to Vite)
TXLINE_BASE_URL=https://txline-dev.txodds.com
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=
TXLINE_FIXTURE_ID=

# Server-side TxOdds fixture discovery for the Live Matches section.
# Use the live fixture endpoint supplied with your TxOdds subscription.
TXODDS_FIXTURES_URL=
TXODDS_USER_ID=
TXODDS_PASSWORD=
TXODDS_FIXTURES_CACHE_MS=60000

# A real Solana checkpoint publisher is intentionally not enabled until a
# program address and narrowly scoped server signer are configured.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_TREASURY_WALLET=6MS566y46t3C37p7TnnK7yieoSbLimWEwwKemXxFMJ5A
SOLANA_CHECKPOINT_PROGRAM_ID=

# Frontend build-time settings (safe public values only)
VITE_SERVER_URL=http://localhost:3001
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_TREASURY_WALLET=6MS566y46t3C37p7TnnK7yieoSbLimWEwwKemXxFMJ5A
